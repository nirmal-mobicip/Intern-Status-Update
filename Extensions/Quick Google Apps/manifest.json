{
    "manifest_version": 3,
    "name": "Quick Google Apps",
    "version": "1.0.0",
    "icons": {
        "16": "images/icon-16.png",
        "128": "images/icon-128.png"
    },
    "background": {
        "service_worker": "service_worker.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "alarms"
    ],
    "minimum_chrome_version": "102",
    "omnibox": {
        "keyword": "gapp"
    }
}